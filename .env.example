# =============================================================================
#  Lage Landen RP — Environment Variables
#  Kopieer dit bestand naar .env en vul de waarden in
# =============================================================================

# ─── MAIN BOT ────────────────────────────────────────────────────────────────
BOT_TOKEN=jouw_discord_bot_token_hier
GUILD_ID=jouw_server_id_hier

# ─── GUARDIAN BOT ────────────────────────────────────────────────────────────
GUARDIAN_BOT_TOKEN=jouw_guardian_bot_token_hier

# ID van de main bot (zodat guardian weet wie hij moet beschermen)
MAIN_BOT_ID=1471546418572296273

# ─── WEBHOOK URLS ────────────────────────────────────────────────────────────
# Webhook voor nood-alerts (bijv. als de bot gebanned wordt)
EMERGENCY_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── KANAAL IDs ──────────────────────────────────────────────────────────────
SECURITY_LOG_CHANNEL_ID=
MOD_LOG_CHANNEL_ID=
TICKET_LOG_CHANNEL_ID=
GENERAL_LOG_CHANNEL_ID=

# Guardian security log (gebruik SECURITY_LOG_CHANNEL_ID als dit leeg is)
GUARDIAN_SECURITY_CHANNEL=

# ─── ROL IDs ─────────────────────────────────────────────────────────────────
QUARANTINE_ROLE_ID=

# ─── FFMPEG (optioneel) ───────────────────────────────────────────────────────
# Pad naar ffmpeg als het niet in PATH staat
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
